# Copy to .env (or .env.local for dev) before running. LAN-only — never commit .env.
#
# At BUILD time, Vite inlines any VITE_* var into the JS bundle. The Docker build
# accepts these as ARGs (see Dockerfile + docker-compose.yml) so Portainer can pass
# them in stack env vars too.

# ── Home Assistant ────────────────────────────────────────────
# Browser-reachable URL (from whatever device runs the dashboard).
# WebSocket path is appended automatically: ws://192.168.1.141:8123/api/websocket
VITE_HA_URL=http://192.168.1.141:8123

# Long-lived access token. Create one in HA → your profile → bottom of page.
VITE_HA_TOKEN=eyJhbGciOiJI...your_long_lived_token...

# ── Deploy (docker-compose / Portainer) ────────────────────────
# Host port the container is exposed on (living-room panel; kitchen uses 8080).
DASHBOARD_PORT=8081

# Container timezone — keeps the clock in the header correct.
TZ=Africa/Johannesburg
